## Patterns ที่ต้องใช้

### API Route Pattern (Next.js 15)
```typescript
// ทุก API route ต้องเป็นแบบนี้:
import { z } from 'zod';
import { NextRequest, NextResponse } from 'next/server';
import { getServerSession } from 'next-auth';
import { rateLimit } from '@/lib/rate-limit';
import { auditLog } from '@/lib/audit';

const schema = z.object({
  // define input schema
});

export async function POST(req: NextRequest) {
  // 1. Rate limit
  const rateLimitResult = await rateLimit(req);
  if (!rateLimitResult.success) {
    return NextResponse.json({ error: 'Too many requests' }, { status: 429 });
  }

  // 2. Auth check (ถ้าต้อง authorize)
  const session = await getServerSession();
  if (!session) {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
  }

  // 3. Input validation
  const body = await req.json();
  const parsed = schema.safeParse(body);
  if (!parsed.success) {
    return NextResponse.json({ error: 'Invalid input' }, { status: 400 });
  }

  // 4. Business logic
  try {
    const result = await doSomething(parsed.data);

    // 5. Audit log
    await auditLog({
      userId: session.user.id,
      action: 'ACTION_NAME',
      resource: 'resource_type',
      details: { /* ... */ },
    });

    // 6. Return filtered response
    return NextResponse.json({ data: filterFields(result) });
  } catch (error) {
    // 7. Safe error handling
    console.error('Internal error:', error);
    return NextResponse.json({ error: 'Internal server error' }, { status: 500 });
  }
}
```

### Middleware Pattern (Auth + RBAC)
```typescript
// middleware.ts
import { withAuth } from 'next-auth/middleware';

export default withAuth({
  callbacks: {
    authorized({ req, token }) {
      const path = req.nextUrl.pathname;

      // Admin routes require admin role
      if (path.startsWith('/admin')) {
        return token?.role === 'admin' || token?.role === 'super_admin';
      }

      // Protected routes require any auth
      if (path.startsWith('/member')) {
        return !!token;
      }

      return true;
    },
  },
});

export const config = {
  matcher: ['/admin/:path*', '/member/:path*', '/api/admin/:path*'],
};
```

